{
  "manifest_version": 3,
  "name": "YouTube Searcher",
  "version": "1.3",
  "description": "Open YouTube search tab using a keyboard shortcut.",
  "permissions": ["tabs", "scripting", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/youtube-16.png",
      "32": "icons/youtube-32.png",
      "64": "icons/youtube-64.png"
    }
  },
  "commands": {
    "search_youtube": {
      "suggested_key": {
        "default": "Ctrl+Y"
      },
      "description": "Open YouTube search page"
    }
  },
  "icons": {
    "16": "icons/youtube-16.png",
    "32": "icons/youtube-32.png",
    "64": "icons/youtube-64.png"
  }
}
